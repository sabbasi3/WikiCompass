AI_GATEWAY_API_KEY=

# Primary model. Any AI Gateway model ID works.
# Browse available models at https://vercel.com/dashboard/ai-gateway/models
AI_MODEL=google/gemini-2.5-flash-lite

# Comma-separated fallback chain (in priority order). The Gateway
# tries the primary model first, then walks this list on transport
# failures (timeouts, rate limits, provider outages). Empty disables
# fallback.
AI_FALLBACK_MODELS=anthropic/claude-haiku-4-5

# Rate limit (optional). Auto-injected when Upstash is provisioned
# via the Vercel marketplace (Storage -> Browse Storage -> Upstash).
# Without these env vars the rate-limiter in lib/rate-limit.ts is
# a no-op, so local dev works without an external dependency.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Postgres (required for the learning-journey feature). Auto-injected
# when Neon is provisioned via the Vercel marketplace (Storage ->
# Browse Storage -> Neon). The serverless driver speaks HTTP, so it
# fits Vercel's compute model without connection pooling pain.
DATABASE_URL=

# HMAC secret for signing journey action URLs (skip-ahead, pause,
# unsubscribe, etc.). Generate with: openssl rand -hex 32
JOURNEY_TOKEN_SECRET=

# Resend (optional). When set, the journey workflow sends real welcome /
# quiz / completion emails to opted-in users. When unset, the email steps
# log a "would have sent" message and continue — local dev works without
# a Resend account.
RESEND_API_KEY=
# Address Resend sends from. Must be a verified sender in your Resend
# account. The default 'onboarding@resend.dev' is Resend's sandbox — it
# only delivers to the account-owner's address, which is fine for demos.
EMAIL_FROM=onboarding@resend.dev
# Base URL embedded in email action links (skip / unsubscribe). Local
# default works for dev; production should be your deployed origin.
NEXT_PUBLIC_APP_URL=http://localhost:3000
